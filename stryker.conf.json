{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "concurrency": 8,
  "mutate": [
    "utils/**/*.ts",
    "services/**/*.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "!**/*.test.ts",
    "!**/*.test.tsx"
  ],
  "ignorePatterns": [
    "node_modules",
    "dist",
    ".claude"
  ],
  "vitest": {
    "related": false
  }
}
